# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram User ID (Super Admin - get from @userinfobot on Telegram)
SUPER_ADMIN_TG_ID=your_telegram_user_id_here

# Session secret (any long random string)
SESSION_SECRET=change_this_to_a_very_long_random_secret_string_at_least_64_chars

# Server port
PORT=3000

# Set to "true" to enable demo mode (OTP shown in API response, no real Telegram bot needed)
DEMO_MODE=false
